{
  "name": "@clawxmemory/clawxmemory-openclaw",
  "version": "0.1.0",
  "description": "OpenClaw memory-slot plugin with L0/L1/L2 local indexes and a minimal dashboard UI.",
  "keywords": [
    "openclaw",
    "plugin",
    "memory",
    "sqlite",
    "ai-agent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/UltraRAG/youarememory.git"
  },
  "bugs": {
    "url": "https://github.com/UltraRAG/youarememory/issues"
  },
  "homepage": "https://github.com/UltraRAG/youarememory#readme",
  "publishConfig": {
    "access": "public"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "agent-skills",
    "skills",
    "openclaw.plugin.json",
    "README.md"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -b --force && node ./scripts/copy-ui.mjs",
    "dev": "tsc -b --watch",
    "typecheck": "tsc -b --pretty false",
    "debug:retrieve": "node ./scripts/debug-retrieve.mjs",
    "lint": "node -e \"console.log('lint skipped for plugin')\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack:check": "npm pack --dry-run",
    "prepack": "npm run build"
  },
  "engines": {
    "node": ">=22.16.0"
  },
  "dependencies": {
    "@sinclair/typebox": "^0.34.41"
  },
  "peerDependencies": {
    "openclaw": ">=2026.3.22"
  },
  "devDependencies": {
    "openclaw": "^2026.3.28",
    "vitest": "^4.0.5"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "compat": {
      "pluginApi": ">=2026.3.22",
      "minGatewayVersion": "2026.3.22"
    },
    "build": {
      "openclawVersion": "2026.3.28"
    }
  }
}
